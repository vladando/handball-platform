generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  PLAYER
  CLUB
  ADMIN
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELLED
}

enum Position {
  GOALKEEPER
  LEFT_BACK
  RIGHT_BACK
  LEFT_WING
  RIGHT_WING
  CENTRE_BACK
  PIVOT
  CENTRE_FORWARD
}

enum ClubVerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum CommissionStatus {
  PENDING
  INVOICED
  PAID
  DISPUTED
  WAIVED
}

enum MedicalRecordType {
  INJURY
  PHYSICAL_TEST
  CLEARANCE
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String
  role          Role
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]
  player        Player?
  club          Club?
  adminProfile  AdminProfile?
  @@map("users")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("sessions")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Player {
  id              String    @id @default(cuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName       String
  lastName        String
  dateOfBirth     DateTime
  nationality     String
  bio             String?   @db.Text
  photoUrl        String?
  heightCm        Int
  weightKg        Int
  dominantHand    String    @default("RIGHT")
  position        Position
  currentClub     String?
  currentSalary   Int?
  expectedSalary  Int?
  availableFrom   DateTime?
  isAvailable     Boolean   @default(true)
  phone           String?
  agentName       String?
  agentPhone      String?
  agentEmail      String?
  slug            String    @unique
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  videos          VideoVault[]
  careerEntries   CareerEntry[]
  medicalRecords  MedicalRecord[]
  interactions    Interaction[]
  watchlistItems  WatchlistItem[]
  @@index([position, isAvailable, heightCm])
  @@index([expectedSalary])
  @@map("players")
}

model VideoVault {
  id          String   @id @default(cuid())
  playerId    String
  player      Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  title       String
  youtubeUrl  String
  description String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  @@map("video_vault")
}

model CareerEntry {
  id            String   @id @default(cuid())
  playerId      String
  player        Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  clubName      String
  country       String
  startDate     DateTime
  endDate       DateTime?
  appearances   Int?
  goals         Int?
  assists       Int?
  isCurrentClub Boolean  @default(false)
  @@map("career_entries")
}

model MedicalRecord {
  id               String            @id @default(cuid())
  playerId         String
  player           Player            @relation(fields: [playerId], references: [id], onDelete: Cascade)
  injuryType       String?
  bodyPart         String?
  injuryDate       DateTime?
  returnDate       DateTime?
  notes            String?           @db.Text
  testName         String?
  testDate         DateTime?
  testResult       String?
  testUnit         String?
  documentUrl      String?
  recordType       MedicalRecordType
  isVisibleToClubs Boolean           @default(false)
  createdAt        DateTime          @default(now())
  @@map("medical_records")
}

model Club {
  id                 String                 @id @default(cuid())
  userId             String                 @unique
  user               User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  name               String
  country            String
  city               String
  leagueName         String?
  logoUrl            String?
  website            String?
  contactEmail       String
  contactPhone       String?
  verificationStatus ClubVerificationStatus @default(PENDING)
  verifiedAt         DateTime?
  verifiedBy         String?
  subscriptionStatus SubscriptionStatus     @default(TRIAL)
  subscriptionEndsAt DateTime?
  slug               String                 @unique
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  interactions       Interaction[]
  watchlist          WatchlistItem[]
  scoutingNotes      ScoutingNote[]
  @@map("clubs")
}

model Interaction {
  id                   String           @id @default(cuid())
  clubId               String
  club                 Club             @relation(fields: [clubId], references: [id])
  playerId             String
  player               Player           @relation(fields: [playerId], references: [id])
  ipAddress            String
  userAgent            String?
  acceptedTosAt        DateTime
  acceptedTosVersion   String           @default("v1.0")
  commissionStatus     CommissionStatus @default(PENDING)
  commissionRate       Decimal          @db.Decimal(5, 4) @default(0.0500)
  invoiceId            String?
  createdAt            DateTime         @default(now()) @db.Timestamptz
  @@unique([clubId, playerId])
  @@index([clubId])
  @@index([playerId])
  @@index([createdAt])
  @@map("interactions")
}

model WatchlistItem {
  id        String   @id @default(cuid())
  clubId    String
  club      Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  playerId  String
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  addedAt   DateTime @default(now())
  notes     String?
  @@unique([clubId, playerId])
  @@map("watchlist_items")
}

model ScoutingNote {
  id        String   @id @default(cuid())
  clubId    String
  club      Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  playerId  String
  content   String   @db.Text
  rating    Int?     @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([clubId, playerId])
  @@map("scouting_notes")
}

model AdminProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("admin_profiles")
}
